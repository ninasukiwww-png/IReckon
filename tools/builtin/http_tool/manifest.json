{
  "name": "HTTP 请求助手",
  "description": "发送 GET/POST/PUT/DELETE 等 HTTP 请求，支持自定义请求头、JSON/原始请求体、超时控制，自动解析响应 JSON。",
  "language": "python",
  "tags": ["http", "network", "api", "utility", "builtin"],
  "input_schema": {
    "type": "object",
    "properties": {
      "method": {"type": "string"},
      "url": {"type": "string"},
      "headers": {"type": "object"},
      "json_data": {"type": "any"},
      "data": {"type": "string"},
      "timeout": {"type": "number"}
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status_code": {"type": "integer"},
      "headers": {"type": "object"},
      "text": {"type": "string"},
      "json": {"type": "any"},
      "elapsed": {"type": "number"},
      "error": {"type": "string"}
    }
  },
  "created_by": "system"
}